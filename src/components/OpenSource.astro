---
import type { SiteContent } from '../i18n';

interface Props {
  content: SiteContent;
}
const { content } = Astro.props;
const { opensource } = content;
---

<section id="opensource" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-24 md:px-10 md:py-32">
  <p class="section-label reveal">{opensource.label}</p>
  <h2 class="reveal mt-4 text-3xl font-bold tracking-tight md:text-5xl">{opensource.heading}</h2>

  <div class="mt-10 grid gap-6 md:grid-cols-2">
    {
      opensource.items.map((item) => (
        <a
          href={item.link}
          target="_blank"
          rel="noopener"
          class="gradient-border reveal group block rounded-2xl bg-surface p-6 transition-transform duration-300 hover:-translate-y-1 md:p-8"
        >
          <div class="flex items-center justify-between gap-3">
            <h3 class="text-xl font-bold tracking-tight md:text-2xl">{item.name}</h3>
            <svg class="size-4 text-muted transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M9 7h8v8" />
            </svg>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="rounded-full border border-stroke px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-muted">
              {item.role}
            </span>
            <span class="accent-text rounded-full border border-stroke px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider">
              ★ {item.stars}
            </span>
          </div>
          <p class="mt-5 text-sm leading-relaxed text-muted md:text-[15px]">{item.desc}</p>
          <ul class="mt-5 space-y-2 text-sm text-muted">
            {item.points.map((p) => (
              <li class="flex gap-3">
                <span class="accent-text mt-0.5 select-none font-mono text-xs">→</span>
                {p}
              </li>
            ))}
          </ul>
        </a>
      ))
    }
  </div>
</section>
