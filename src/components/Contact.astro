---
import type { SiteContent } from '../i18n';

interface Props {
  content: SiteContent;
}
const { content } = Astro.props;
const { contact } = content;
---

<footer id="contact" class="mx-auto max-w-6xl scroll-mt-24 px-5 pb-10 pt-24 md:px-10 md:pt-32">
  <p class="section-label reveal">{contact.label}</p>

  <a href="mailto:czyklein@outlook.com" class="group block">
    <h2 class="reveal mt-6 font-display text-[15vw] italic leading-none tracking-tight transition-colors duration-300 group-hover:text-transparent md:text-9xl contact-heading">
      {contact.heading}
    </h2>
  </a>
  <p class="reveal mt-6 max-w-md text-[15px] text-muted md:text-base">{contact.sub}</p>

  <ul class="reveal mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-x-8">
    {
      contact.links.map((l) => (
        <li>
          <a
            href={l.href}
            target={l.href.startsWith('http') ? '_blank' : undefined}
            rel={l.href.startsWith('http') ? 'noopener' : undefined}
            class="nav-underline inline-flex min-h-11 items-center font-mono text-xs uppercase tracking-wider text-body sm:min-h-0"
          >
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="mt-16 flex flex-wrap items-center justify-between gap-4 border-t border-stroke pt-6">
    <p class="font-mono text-[10px] uppercase tracking-wider text-muted">{contact.copyright}</p>
    <div class="flex items-center gap-6">
      <span id="local-clock" class="font-mono text-[10px] tabular-nums tracking-wider text-muted" aria-hidden="true"></span>
      <a href="#top" class="nav-underline font-mono text-[10px] uppercase tracking-wider text-muted hover:text-body">
        {contact.backToTop} ↑
      </a>
    </div>
  </div>
</footer>

<style>
  .contact-heading {
    -webkit-text-stroke: 0px var(--text);
    transition: color 0.35s ease, -webkit-text-stroke 0.35s ease;
  }
  .group:hover .contact-heading {
    -webkit-text-stroke: 1.5px var(--text);
  }
</style>

<script>
  const clock = document.getElementById('local-clock');
  if (clock) {
    const fmt = new Intl.DateTimeFormat('en-GB', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    });
    const tick = () => (clock.textContent = fmt.format(new Date()));
    tick();
    setInterval(tick, 1000);
  }
</script>
